VITE_API_BASE_URL=http://localhost:105
# true(기본) = mock 데이터, false = BE 실 HTTP
VITE_USE_MOCK_API=true
# API 모드 웹 dev용 OAuth 토큰 (BE /auth/google|apple)
# VITE_DEV_ID_TOKEN=dev-token

# Phase 3 native billing
# RevenueCat dashboard에서 발급받은 public SDK key
# VITE_REVENUECAT_IOS_API_KEY=appl_xxxxxxxxxxxxxxxxxxxx
# VITE_REVENUECAT_ANDROID_API_KEY=goog_xxxxxxxxxxxxxxxxxxxx
# RevenueCat entitlement/package id
VITE_REVENUECAT_ENTITLEMENT_ID=premium
# VITE_REVENUECAT_PACKAGE_ID=$rc_monthly
# Store 구독 관리 fallback URL
# VITE_IOS_SUBSCRIPTION_MANAGEMENT_URL=https://apps.apple.com/account/subscriptions
# VITE_ANDROID_SUBSCRIPTION_MANAGEMENT_URL=https://play.google.com/store/account/subscriptions
